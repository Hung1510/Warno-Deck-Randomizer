# Discord Developer Portal -> your application -> Bot -> Token
DISCORD_TOKEN=

# Discord Developer Portal -> your application -> General Information -> Application ID
DISCORD_CLIENT_ID=

# Optional: a server (guild) ID for instant command registration during
# development. Guild-scoped commands appear immediately; global commands
# (leave this blank) can take up to an hour to propagate to all servers.
DISCORD_GUILD_ID=

# Base URL of your deployed WARNO Deck Randomizer API. Defaults to
# http://localhost:4000 if unset -- fine for local testing against
# `npm run dev` in backend/, but a real deployment needs a real public URL.
API_BASE_URL=http://localhost:4000